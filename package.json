{
  "name": "menubit",
  "version": "0.1.0",
  "private": true,
  "description": "Menubit — SaaS multi-tenant modular para hostelería",
  "license": "UNLICENSED",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "db:generate": "turbo run db:generate",
    "db:migrate": "npm run db:migrate --workspace=@menubit/api",
    "db:deploy": "npm run db:deploy --workspace=@menubit/api",
    "db:studio": "npm run db:studio --workspace=@menubit/api"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.1.3"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@10.9.7"
}
